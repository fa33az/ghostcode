{
  "name": "ghostcode",
  "version": "1.0.0",
  "description": "CLI tool to detect Zombie Code in TypeScript projects",
  "main": "dist/index.js",
  "bin": {
    "ghostcode": "dist/index.js",
    "silent-failure-detector": "dist/index.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsup src/index.ts --format esm --clean --dts",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts"
  },
  "keywords": [
    "zombie-code",
    "static-analysis",
    "ts-morph",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "ts-morph": "^22.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.9",
    "tsup": "^8.1.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
